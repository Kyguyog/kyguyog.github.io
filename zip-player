<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ZIP Game Loader</title>
  <style>
    :root { color-scheme: dark; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      background: radial-gradient(circle at top, #1d2141 0%, #090b15 60%);
      color: #ebedff;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 1rem;
      box-sizing: border-box;
    }
    .panel {
      width: min(800px, 100%);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 14px;
      background: rgba(15, 18, 36, 0.92);
      padding: 1rem;
      box-sizing: border-box;
      box-shadow: 0 18px 40px rgba(0,0,0,0.35);
    }
    .title { margin: 0 0 0.35rem; font-size: 1.08rem; }
    .hint { margin: 0 0 0.9rem; color: #b9c0eb; font-size: 0.9rem; }
    .drop {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      width: 100%;
      box-sizing: border-box;
      border: 1px dashed rgba(163, 180, 255, 0.55);
      border-radius: 10px;
      padding: 1.2rem;
      text-align: center;
      background: rgba(124, 92, 255, 0.08);
      transition: background 120ms ease, border-color 120ms ease;
      cursor: pointer;
    }
    .drop.dragover {
      background: rgba(124, 92, 255, 0.2);
      border-color: rgba(163, 180, 255, 0.95);
    }
    .file-btn {
      margin-top: 0;
      border: 1px solid rgba(255,255,255,0.28);
      border-radius: 8px;
      background: rgba(255,255,255,0.08);
      color: #ebedff;
      padding: 0.45rem 0.75rem;
      font-size: 0.85rem;
      cursor: pointer;
    }
    .status { margin: 0.8rem 0 0; color: #bec5ef; font-size: 0.92rem; }
    .status.err { color: #ff9f9f; }
    .status.ok { color: #88f1ad; }
  </style>
</head>
<body>
  <div class="panel">
    <h1 class="title">Upload a ZIP Game</h1>
    <p class="hint">Upload a <code>.zip</code> containing game files. We launch <code>index.html</code> first, otherwise another root-level <code>.html</code>.</p>
    <label class="drop" id="drop-zone">
      <div>Drop ZIP here or click to choose a file.</div>
      <button class="file-btn" type="button" id="pick-btn">Choose ZIP</button>
      <input id="zip-file" type="file" accept=".zip,application/zip" style="display:none;" />
    </label>
    <p class="status" id="status">Waiting for file…</p>
  </div>

  <script type="module">
    import { unzipSync, strFromU8 } from 'https://cdn.jsdelivr.net/npm/fflate@0.8.2/esm/browser.js';

    const statusEl = document.getElementById('status');
    const zipInput = document.getElementById('zip-file');
    const drop = document.getElementById('drop-zone');
    const pickBtn = document.getElementById('pick-btn');

    function setStatus(msg, cls = '') {
      statusEl.textContent = msg;
      statusEl.className = `status ${cls}`.trim();
    }

    function normalizePath(path) {
      return (path || '').replace(/^\/+/, '').replace(/\\/g, '/').split('/').filter(Boolean).join('/');
    }

    function contentType(path) {
      const lower = path.toLowerCase();
      if (lower.endsWith('.html') || lower.endsWith('.htm')) return 'text/html; charset=utf-8';
      if (lower.endsWith('.js') || lower.endsWith('.mjs')) return 'text/javascript; charset=utf-8';
      if (lower.endsWith('.css')) return 'text/css; charset=utf-8';
      if (lower.endsWith('.json')) return 'application/json; charset=utf-8';
      if (lower.endsWith('.svg')) return 'image/svg+xml';
      if (lower.endsWith('.png')) return 'image/png';
      if (lower.endsWith('.jpg') || lower.endsWith('.jpeg')) return 'image/jpeg';
      if (lower.endsWith('.webp')) return 'image/webp';
      if (lower.endsWith('.gif')) return 'image/gif';
      if (lower.endsWith('.ico')) return 'image/x-icon';
      if (lower.endsWith('.mp3')) return 'audio/mpeg';
      if (lower.endsWith('.ogg')) return 'audio/ogg';
      if (lower.endsWith('.wav')) return 'audio/wav';
      if (lower.endsWith('.mp4')) return 'video/mp4';
      if (lower.endsWith('.webm')) return 'video/webm';
      if (lower.endsWith('.wasm')) return 'application/wasm';
      if (lower.endsWith('.xml')) return 'application/xml; charset=utf-8';
      if (lower.endsWith('.txt')) return 'text/plain; charset=utf-8';
      return 'application/octet-stream';
    }

    async function ensureSw() {
      if (!('serviceWorker' in navigator)) throw new Error('This browser does not support service workers.');
      const reg = await navigator.serviceWorker.register('/zip-sw.js', { scope: '/' });
      await navigator.serviceWorker.ready;
      if (reg.waiting) reg.waiting.postMessage({ type: 'SKIP_WAITING' });
    }

    function chooseEntry(fileMap) {
      if (fileMap.has('index.html')) return 'index.html';
      const nestedIndex = [...fileMap.keys()].find((name) => /(^|\/)index\.html?$/i.test(name));
      if (nestedIndex) return nestedIndex;
      const rootHtml = [...fileMap.keys()].find((name) => !name.includes('/') && /\.html?$/i.test(name));
      if (rootHtml) return rootHtml;
      return [...fileMap.keys()].find((name) => /\.html?$/i.test(name)) || '';
    }

    async function loadZipToCache(zipArrayBuffer, runtimeId) {
      const cache = await caches.open('zip-runtime');
      const files = unzipSync(new Uint8Array(zipArrayBuffer));
      const fileMap = new Map();
      const root = `${location.origin}/__zip_runtime/${runtimeId}/`;

      let fileCount = 0;
      for (const [name, bytes] of Object.entries(files)) {
        const clean = normalizePath(name);
        if (!clean) continue;
        if (clean.endsWith('/')) continue;

        const ct = contentType(clean);
        const headers = { 'Content-Type': ct };
        const body = (ct.startsWith('text/') || ct.includes('javascript') || ct.includes('json') || ct.includes('xml'))
          ? strFromU8(bytes)
          : bytes;

        await cache.put(new Request(root + clean), new Response(body, { status: 200, headers }));
        fileMap.set(clean, true);
        fileCount += 1;
      }

      return { fileCount, entry: chooseEntry(fileMap) };
    }

    async function runZip(file) {
      if (!file) return;
      if (!/\.zip$/i.test(file.name || '')) throw new Error('Please choose a .zip file.');

      setStatus('Starting ZIP runtime…');
      await ensureSw();

      setStatus('Reading ZIP file…');
      const ab = await file.arrayBuffer();
      const runtimeId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;

      setStatus('Extracting and caching game files…');
      const { fileCount, entry } = await loadZipToCache(ab, runtimeId);
      if (!fileCount) throw new Error('ZIP had no readable files.');
      if (!entry) throw new Error('No root-level .html file found in ZIP.');

      setStatus(`Launching ${entry}…`, 'ok');
      location.replace(`/__zip_runtime/${runtimeId}/${entry}`);
    }


    zipInput.addEventListener('change', async () => {
      try {
        await runZip(zipInput.files && zipInput.files[0]);
      } catch (err) {
        setStatus(err && err.message ? err.message : 'Failed to load ZIP game.', 'err');
      }
    });

    pickBtn.addEventListener('click', () => zipInput.click());
    drop.addEventListener('dragover', (e) => {
      e.preventDefault();
      drop.classList.add('dragover');
    });
    drop.addEventListener('dragleave', () => drop.classList.remove('dragover'));
    drop.addEventListener('drop', async (e) => {
      e.preventDefault();
      drop.classList.remove('dragover');
      try {
        const file = e.dataTransfer && e.dataTransfer.files ? e.dataTransfer.files[0] : null;
        await runZip(file);
      } catch (err) {
        setStatus(err && err.message ? err.message : 'Failed to load ZIP game.', 'err');
      }
    });

  </script>
</body>
</html>
